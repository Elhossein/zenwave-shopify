/* Shared */
.zw-inner{max-width:1100px;margin:0 auto;}
.zw-eyebrow{font-size:0.68rem;font-weight:800;letter-spacing:0.14em;color:#7c3aed;text-transform:uppercase;margin-bottom:10px;}
