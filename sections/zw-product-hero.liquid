/* Sticky */
.zw-sticky{position:fixed;bottom:0;left:0;right:0;z-index:600;background:#fff;border-top:1px solid #e5e5e5;box-shadow:0 -4px 20px rgba(0,0,0,0.1);padding:12px 20px;display:flex;align-items:center;gap:16px;transform:translateY(100%);transition:transform 0.3s ease;}
.zw-sticky-left{flex:1;}
.zw-sticky-left strong{display:block;font-size:0.85rem;color:#111;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:220px;}
.zw-sticky-left span{font-size:1rem;font-weight:900;color:#7c3aed;}
.zw-sticky-btn{background:linear-gradient(135deg,#4c1d95,#7c3aed);color:#fff;border:none;border-radius:10px;padding:12px 28px;font-size:0.9rem;font-weight:800;cursor:pointer;white-space:nowrap;flex-shrink:0;}
