{%- assign zp = product -%}
{%- assign zfv = zp.selected_or_first_available_variant -%}

<!-- ══ PRODUCT HERO ══ -->
<section class="zw-hero">
  <div class="zw-hero-wrap">

    <!-- LEFT: Sticky Gallery -->
    <div class="zw-gallery" id="zw-gallery">
      <div class="zw-gallery-main">
        {%- if zp.images.size > 0 -%}
          <img id="zw-main-img" src="{{ zp.featured_image | image_url: width: 1000 }}" alt="{{ zp.title }}" />
        {%- else -%}
          <img id="zw-main-img" src="{{ 'qvc-1.jpg' | asset_url }}" alt="{{ zp.title }}" />
        {%- endif -%}
        <span class="zw-badge">#1 Best Seller</span>
      </div>
      <div class="zw-thumbs">
        {%- if zp.images.size > 0 -%}
          {%- for img in zp.images -%}
            <button class="zw-thumb{% if forloop.first %} active{% endif %}" data-src="{{ img | image_url: width: 1000 }}">
              <img src="{{ img | image_url: width: 120 }}" alt="{{ zp.title }}" loading="lazy" />
            </button>
          {%- endfor -%}
        {%- else -%}
          {%- assign zw_fallback_imgs = 'qvc-1.jpg,qvc-2.jpg,qvc-3.jpg,qvc-4.jpg,qvc-5.jpg,qvc-6.jpg,qvc-7.jpg,mm-1.jpg,mm-g3.jpg,mm-g4.jpg' | split: ',' -%}
          {%- for zfi in zw_fallback_imgs -%}
            <button class="zw-thumb{% if forloop.first %} active{% endif %}" data-src="{{ zfi | asset_url }}">
              <img src="{{ zfi | asset_url }}" alt="{{ zp.title }}" loading="lazy" />
            </button>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>

    <!-- RIGHT: Product Info -->
    <div class="zw-info">
      <div class="zw-rating-row">
        <span class="zw-stars">★★★★★</span>
        <span class="zw-rating-num">4.9 / 5</span>
        <span class="zw-sep">·</span>
        <span>Loved by <strong>30,000+</strong> customers</span>
      </div>

      <h1 class="zw-title">{{ zp.title }}</h1>
      <p class="zw-subtitle">Professional full-body shiatsu relief — <strong>neck, cervical, shoulders, back, waist, legs</strong> all in one mat. Zero effort. Total relaxation.</p>

      <div class="zw-price-block">
        <span class="zw-price" id="zw-price">{{ zfv.price | money }}</span>
        {%- if zfv.compare_at_price > zfv.price -%}
          <s class="zw-was" id="zw-was">{{ zfv.compare_at_price | money }}</s>
          {%- assign spct = zfv.compare_at_price | minus: zfv.price | times: 100 | divided_by: zfv.compare_at_price -%}
          <span class="zw-save-pill">SAVE {{ spct }}%</span>
        {%- endif -%}
      </div>
      <p class="zw-pay-line">or 4 interest-free payments of <strong>{{ zfv.price | divided_by: 4 | money }}</strong> with <strong>Shop Pay</strong></p>

      <script id="zw-variant-data" type="application/json">
        [{%- for v in zp.variants -%}{"id":{{ v.id }},"price":{{ v.price }},"compare_at_price":{{ v.compare_at_price | default: 0 }},"available":{{ v.available }}}{% unless forloop.last %},{% endunless %}{%- endfor -%}]
      </script>

      <ul class="zw-bullets">
        <li><svg viewBox="0 0 20 20" fill="#7c3aed" width="18" height="18"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg><span>69" full-body coverage — neck to feet in one mat</span></li>
        <li><svg viewBox="0 0 20 20" fill="#7c3aed" width="18" height="18"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg><span>Shiatsu kneading + vibration + optional heat therapy</span></li>
        <li><svg viewBox="0 0 20 20" fill="#7c3aed" width="18" height="18"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg><span>Multiple intensity levels — adjustable for any sensitivity</span></li>
        <li><svg viewBox="0 0 20 20" fill="#7c3aed" width="18" height="18"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg><span>Foldable &amp; portable — use at home, office, or travel</span></li>
        <li><svg viewBox="0 0 20 20" fill="#7c3aed" width="18" height="18"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg><span>Auto shut-off safety timer — worry-free sessions</span></li>
      </ul>

      <button class="zw-cta" id="zw-cta">
        Add to Cart — <span id="zw-cta-price">{{ zfv.price | money }}</span>
      </button>

      <div class="zw-stock-wrap">
        <div class="zw-stock-bar"><div class="zw-stock-fill" style="width:82%"></div></div>
        <p class="zw-stock-text">⚡ <strong>82% SOLD</strong> — Only 9 left at this price</p>
      </div>

      <div class="zw-guarantee">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="28" height="28"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <div>
          <strong>30-Day Money-Back Guarantee</strong>
          <span>Feel the difference or get a full refund. 100% risk-free.</span>
        </div>
      </div>

      <div class="zw-trust">
        <div class="zw-trust-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="20" height="20"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg><span>Free Shipping</span></div>
        <div class="zw-trust-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="20" height="20"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg><span>Secure Checkout</span></div>
        <div class="zw-trust-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="20" height="20"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg><span>1-Year Warranty</span></div>
      </div>

      <div class="zw-accordions">
        <details class="zw-acc"><summary class="zw-acc-q">What's in the Box <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><polyline points="6 9 12 15 18 9"/></svg></summary><p class="zw-acc-a">1× ZenWave Full-Body Massage Mat (69" × 24") · Remote control · Power adapter · Storage bag · Quick-start guide.</p></details>
        <details class="zw-acc"><summary class="zw-acc-q">How to Use <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><polyline points="6 9 12 15 18 9"/></svg></summary><p class="zw-acc-a">Unroll on any flat surface. Lie down, plug in, and select your zone and intensity on the remote. Start with 15–20 minute sessions. Auto shut-off activates after your set time.</p></details>
        <details class="zw-acc"><summary class="zw-acc-q">Shipping &amp; Returns <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><polyline points="6 9 12 15 18 9"/></svg></summary><p class="zw-acc-a">Free US shipping on all orders. Ships in 1–2 business days, arrives in 3–7 days. 30-day hassle-free returns — we cover return shipping.</p></details>
      </div>
    </div>
  </div>
</section>

<!-- ══ VIDEOS ══ -->
{%- assign zw_vid_count = 0 -%}
{%- for media in zp.media -%}
  {%- if media.media_type == 'video' or media.media_type == 'external_video' -%}
    {%- assign zw_vid_count = zw_vid_count | plus: 1 -%}
  {%- endif -%}
{%- endfor -%}
{%- if zw_vid_count > 0 or true -%}
<section class="zw-vid-section">
  <div class="zw-inner">
    <p class="zw-eyebrow">SEE IT IN ACTION</p>
    <h2 class="zw-sec-h2" style="margin-bottom:40px">Watch How It Works</h2>
    {%- assign zw_vn = 0 -%}
    {%- for media in zp.media -%}
      {%- if media.media_type == 'video' or media.media_type == 'external_video' -%}
        {%- if zw_vn == 0 -%}
          <div class="zw-vid-featured">
            {%- if media.media_type == 'video' -%}
              <video controls autoplay muted loop playsinline{% if media.preview_image %} poster="{{ media.preview_image | image_url: width: 1200 }}"{% endif %}>
                {%- for src in media.sources -%}<source src="{{ src.url }}" type="{{ src.mime_type }}">{%- endfor -%}
              </video>
            {%- elsif media.host == 'youtube' -%}
              <iframe src="https://www.youtube.com/embed/{{ media.external_id }}?autoplay=1&mute=1&rel=0" frameborder="0" allowfullscreen allow="autoplay;encrypted-media"></iframe>
            {%- endif -%}
          </div>
          {%- if zw_vid_count > 1 -%}<div class="zw-vid-row">{%- endif -%}
        {%- else -%}
          <div class="zw-vid-card"
            {%- if media.media_type == 'video' -%}{%- for src in media.sources limit:1 %} data-src="{{ src.url }}" data-mime="{{ src.mime_type }}"{% endfor %}{% if media.preview_image %} data-poster="{{ media.preview_image | image_url: width:800 }}"{% endif %}
            {%- elsif media.host == 'youtube' -%} data-yt="{{ media.external_id }}"{%- endif -%}>
            <div class="zw-vid-thumb">
              {%- if media.preview_image -%}<img src="{{ media.preview_image | image_url: width:400 }}" alt="Video {{ zw_vn | plus:1 }}" loading="lazy">{%- else -%}<div style="width:100%;height:100%;background:#1a1a2e"></div>{%- endif -%}
              <div class="zw-vid-play"><svg viewBox="0 0 24 24" width="52" height="52"><circle cx="12" cy="12" r="12" fill="rgba(0,0,0,0.6)"/><polygon points="10,8 18,12 10,16" fill="white"/></svg></div>
            </div>
            <p class="zw-vid-label">Video {{ zw_vn | plus:1 }}</p>
          </div>
        {%- endif -%}
        {%- assign zw_vn = zw_vn | plus: 1 -%}
      {%- endif -%}
    {%- endfor -%}
    {%- if zw_vid_count > 1 -%}</div>{%- endif -%}
    {%- if zw_vid_count == 0 -%}
      <!-- Fallback: asset video -->
      <div class="zw-vid-featured">
        <video controls muted loop playsinline poster="{{ 'qvc-video-poster.jpg' | asset_url }}">
          <source src="{{ 'qvc-video-compressed.mp4' | asset_url }}" type="video/mp4">
        </video>
      </div>
    {%- endif -%}
  </div>
  <div class="zw-vid-lb" id="zw-vid-lb" aria-hidden="true">
    <button id="zw-vid-lb-close" class="zw-vid-lb-close">✕</button>
    <div id="zw-vid-lb-body" class="zw-vid-lb-body"></div>
  </div>
  <script>
  (function(){
    var lb=document.getElementById('zw-vid-lb'),lbBody=document.getElementById('zw-vid-lb-body');
    function closeLb(){lb.setAttribute('aria-hidden','true');lbBody.innerHTML='';document.body.style.overflow='';}
    document.getElementById('zw-vid-lb-close').addEventListener('click',closeLb);
    lb.addEventListener('click',function(e){if(e.target===lb)closeLb();});
    document.querySelectorAll('.zw-vid-card').forEach(function(c){
      c.addEventListener('click',function(){
        lbBody.innerHTML='';
        if(c.dataset.yt){lbBody.innerHTML='<iframe src="https://www.youtube.com/embed/'+c.dataset.yt+'?autoplay=1&rel=0" frameborder="0" allowfullscreen allow="autoplay;encrypted-media" style="width:100%;aspect-ratio:16/9;border-radius:16px;display:block"></iframe>';}
        else if(c.dataset.src){var v=document.createElement('video');v.controls=true;v.autoplay=true;v.muted=true;v.setAttribute('playsinline','');if(c.dataset.poster)v.poster=c.dataset.poster;v.innerHTML='<source src="'+c.dataset.src+'" type="'+(c.dataset.mime||'video/mp4')+'">';lbBody.appendChild(v);}
        lb.setAttribute('aria-hidden','false');document.body.style.overflow='hidden';
      });
    });
  })();
  </script>
</section>
{%- endif -%}

