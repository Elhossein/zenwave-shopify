/* Footer */
.zw-footer{background:#1a1a2e;color:rgba(255,255,255,0.65);padding:56px 24px 24px;}
.zw-footer-inner{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:2fr 1fr 1fr;gap:40px;margin-bottom:40px;}
@media(max-width:640px){.zw-footer-inner{grid-template-columns:1fr;gap:32px;}}
.zw-footer-brand{font-size:1.5rem;font-weight:900;color:#fff;margin-bottom:8px;}
.zw-footer-tag{font-size:0.85rem;color:rgba(255,255,255,0.4);}
.zw-footer-col{display:flex;flex-direction:column;gap:0;}
.zw-footer-col strong{font-size:0.75rem;font-weight:700;color:#a78bfa;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:12px;}
.zw-footer-col a{font-size:0.85rem;color:rgba(255,255,255,0.5);padding:4px 0;transition:color 0.15s;}
.zw-footer-col a:hover{color:#a78bfa;}
.zw-footer-bottom{max-width:1100px;margin:0 auto;border-top:1px solid rgba(255,255,255,0.08);padding-top:20px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;}
